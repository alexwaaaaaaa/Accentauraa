{
  "name": "accentaura-backend",
  "version": "1.0.0",
  "description": "Backend API for Accentaura language learning platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "seed:lessons": "ts-node prisma/seed-lessons.ts",
    "seed:badges": "ts-node prisma/seed-badges.ts",
    "seed:all": "./scripts/seed-all.sh",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
